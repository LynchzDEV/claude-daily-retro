# daily-retro runtime config. Copied to ~/.claude/skills/daily-retro/config.env
# by install.sh. Edit + reload (re-run install.sh) to change behavior.
MODE="apply"          # apply = auto-edit CLAUDE.md/changelog ; propose = write 03-proposals.md only
CATCHUP_DAYS=7        # how many past days to back-fill on a missed/booted run
RUN_HOUR=18           # hour-of-day the scheduler fires (also set in the plist/cron)
ALLOWED="Read,Write,Edit,Bash,Grep,Glob,Skill,Agent,Task"
RETRO_MODEL=""        # pin a model for retro runs ("sonnet", "haiku"); empty = account default
RETRY_MAX=3           # rate-limit retries per date before giving up until next schedule
RETRY_FALLBACK_MIN=60 # minutes to wait when the limit-reset time can't be parsed
RETRY_CAP_MIN=300     # hard cap (minutes) on any single retry wait
GENERIC_RETRY_MAX=1      # retries for non-rate-limit failures (rc!=0 or missing step sentinels)
GENERIC_RETRY_WAIT_MIN=10 # minutes between generic retries
RETENTION_DAYS=30        # prune bulky raw capture files (raw-*, user-msgs*) in retro/<date>/ after this many days
