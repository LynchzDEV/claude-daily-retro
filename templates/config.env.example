# daily-retro runtime config. Copied to ~/.claude/skills/daily-retro/config.env
# by install.sh. Edit + reload (re-run install.sh) to change behavior.
MODE="apply"        # apply = auto-edit CLAUDE.md/changelog ; propose = write 03-proposals.md only
CATCHUP_DAYS=7      # how many past days to back-fill on a missed/booted run
RUN_HOUR=18         # hour-of-day the scheduler fires (also set in the plist/cron)
ALLOWED="Read,Write,Edit,Bash,Grep,Glob,Skill,Agent,Task"
